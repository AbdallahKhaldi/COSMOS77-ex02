# COSMOS77-ex02 environment variables — placeholders only.
# Copy this file to `.env` (which is gitignored) and fill in real values locally.
#
# IMPORTANT: this project needs NO API key to run. The LLM backend is the
# `claude` CLI authenticated with your Claude Max/Pro subscription login
# (`claude` then `/login`). Never commit credentials — see CLAUDE.md rule 9.

# Optional: a fallback web-search backend used ONLY if the primary
# `claude -p --allowedTools WebSearch` path is unavailable (see PRD_web_search).
WEB_SEARCH_API_KEY=your_key_here

# Logging level override (DEBUG, INFO, WARNING, ERROR).
COSMOS77_LOG_LEVEL=INFO
